{
  "rules": {
    ".read": false,
    ".write": false,
    "rides": {
      "$rideId": {
        ".read": true,
        "location": {
          ".write": true,
          ".validate": "newData.hasChildren(['lat', 'lng', 'accuracy', 'timestamp']) && newData.child('lat').isNumber() && newData.child('lng').isNumber() && newData.child('accuracy').isNumber() && newData.child('timestamp').isNumber()"
        }
      }
    }
  }
}